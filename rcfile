  function fApplyMonsAlert(mons)
    crawl.setopt("monster_alert += " .. mons)
  end

  gLaxMonsAlerts = {"Erolcha"}
  gNormalMonsAlerts = {"shining eye, eye of draining"}
  gHarshMonsAlerts = {"uniques"}

  function fSetForceMores(setting)
    fApplyLaxForceMores()
    crawl.setopt("monster_alert = ")
    util.foreach(gLaxMonsAlerts, fApplyMonsAlert)

    if setting == "normal" then
      fApplyNormalForceMores()
      util.foreach(gNormalMonsAlerts, fApplyMonsAlert)
    end

    if setting == "harsh" then
      fApplyNormalForceMores()
      fApplyHarshForceMores()
      util.foreach(gHarshMonsAlerts, fApplyMonsAlert)
    end
  end
}

